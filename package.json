{
  "name": "sufi-url-validator",
  "version": "1.0.0",
  "description": "Automated URL / redirect validator for the SUFI migration using Playwright",
  "main": "index.js",
  "scripts": {
    "validate": "ts-node src/validator.ts",
    "validate:release": "RELEASE_NUMBER=1 ts-node src/validator.ts",
    "test": "playwright test",
    "test:urls": "playwright test tests/assets.spec.ts",
    "test:header": "playwright test tests/header-nav.spec.ts",
    "report": "allure generate allure-results --clean -o allure-report && allure open allure-report --port 4040",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "test:report": "npm run test && npm run report:generate && allure open allure-report --port 4040",
    "build": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "fast-csv": "^5.0.1",
    "form-data": "^4.0.5",
    "p-limit": "^3.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/form-data": "^2.2.1",
    "@types/node": "^20.12.12",
    "allure-commandline": "^2.38.1",
    "allure-js-commons": "^3.7.2",
    "allure-playwright": "^3.7.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
