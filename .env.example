# ============================================================
# Contentful Configuration
# ============================================================

# Space ID — the identifier for your Contentful space
# Found in: Contentful -> Settings -> API Keys -> Space ID
CONTENTFUL_SPACE_ID=catp2t59asao

# Content Delivery API (CDA) access token
# Found in: Contentful -> Settings -> API Keys -> Content Delivery API - access token
# Use PREVIEW token for draft content validation
CONTENTFUL_ACCESS_TOKEN=your_cda_access_token_here

# Contentful environment (default: master)
CONTENTFUL_ENVIRONMENT=master

# ============================================================
# Validation Configuration
# ============================================================

# Path to the CSV file with asset IDs
# Default: ./Resources/images.csv
CSV_PATH=./Resources/images.csv

# Concurrency: how many parallel requests to Contentful CDA
# Keep between 3-8 to stay within rate limits (7 req/s on free tier)
CONCURRENCY=5

# Retry failed requests up to N times before marking as FAIL
MAX_RETRIES=3

# Delay in milliseconds between retry attempts
RETRY_DELAY_MS=1000

# ============================================================
# Release / Batch Configuration
# ============================================================

# Which release batch to process (1-4). Leave empty to process all.
RELEASE_NUMBER=1

# Total number of releases (used to calculate batch slice)
TOTAL_RELEASES=4

# ============================================================
# Output Configuration
# ============================================================

# Directory where reports are saved
REPORT_DIR=./reports

# Report format: json | csv | both
REPORT_FORMAT=both
