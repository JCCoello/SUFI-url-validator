# ---------------------------------------------------------------
# SUFI URL Validator — environment configuration
# Copy to .env and fill in values. .env is gitignored.
# ---------------------------------------------------------------

# Vercel visitor password for the protected preview deployments (required)
VERCEL_BYPASS_TOKEN=

# Path to the CSV of URLs to validate (must have a "url" column header)
# CSV_PATH=./Resources/urls.csv

# Parallel in-flight HTTP requests (1-100)
# CONCURRENCY=20

# Retry attempts on network errors / HTTP 429 / 5xx
# MAX_RETRIES=3

# Base delay (ms) for exponential backoff between retries
# RETRY_DELAY_MS=1000

# Which release batch to validate (1-based). Omit to validate all URLs.
# RELEASE_NUMBER=1

# Total number of release batches (used with RELEASE_NUMBER)
# TOTAL_RELEASES=4

# Output directory for reports
# REPORT_DIR=./reports

# Report format: json | csv | both
# REPORT_FORMAT=both

# Slack notification (optional)
# SLACK_ENABLED=true
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
